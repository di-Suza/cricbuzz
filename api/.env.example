PORT=3000
MONGODB_URI=mongodb://localhost:27017/cricbuzz_backend
JWT_PRIVATE_KEY_BASE64=base64_encoded_private_key_here
JWT_PUBLIC_KEY_BASE64=base64_encoded_public_key_here
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=2d
REFRESH_COOKIE_NAME=refreshToken
REFRESH_COOKIE_MAX_AGE_MS=172800000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
CORS_ORIGIN=*
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-this-super-admin-password
