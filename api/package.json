{
  "name": "cricket-admin-backend",
  "version": "1.0.0",
  "description": "Class-based cricket admin backend foundation with Express, MongoDB, Socket.IO, JWT RBAC, Zod env validation, and express-validator API validation.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon ./src/server.js",
    "start": "node ./src/server.js",
    "seed:super-admin": "node ./src/seed/superAdmin.js",
    "check": "node --check ./src/server.js",
    "test": "npm run check"
  },
  "keywords": [
    "cricket",
    "express",
    "mongodb",
    "socket.io"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@imagekit/nodejs": "^7.7.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cricbuzz-workspace": "file:..",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
